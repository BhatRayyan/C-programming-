#include <stdio.h>

int main()
{
    char mat[100];
    char name[100];
    // scanf() can only read a single word, so it will stop reading input at the first whitespace character (space, tab, newline, etc.). If you want to read a full line of input, you can use fgets() instead.
    printf("Enter your name: ");
    scanf("%s", &mat);
    // fgets() can read an entire line of input, including spaces, until it encounters a newline character or reaches the specified buffer size. It also adds a null terminator at the end of the string.
    
    getchar(); // Consume the newline character left in the input buffer by scanf(). Syntax is fgets(array_name, size, stdin);
    printf("Enter your name: ");
    fgets(name, 100, stdin); 
    printf("%s", name);
    printf("%s", mat);
    return 0;
}
